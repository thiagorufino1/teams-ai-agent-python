# This file includes environment variables that will be committed to git by default.

# Built-in environment variables
TEAMSFX_ENV=dev
APP_NAME_SUFFIX=dev
APP_SHORT_NAME=TRC Agent
APP_FULL_NAME=TRC Microsoft 365 Agent
APP_DESCRIPTION_SHORT=AI agent for Microsoft Teams with Azure OpenAI
APP_DESCRIPTION_FULL=Microsoft 365 agent for Teams with streaming responses, conversation memory, and Azure OpenAI integration.
APP_DEVELOPER_NAME=Thiago Rufino
APP_DEVELOPER_WEBSITE=https://www.linkedin.com/in/thiagorufinocarvalho
APP_DEVELOPER_PRIVACY_URL=https://www.linkedin.com/in/thiagorufinocarvalho
APP_DEVELOPER_TERMS_URL=https://www.linkedin.com/in/thiagorufinocarvalho

# Updating AZURE_SUBSCRIPTION_ID or RESOURCE_SUFFIX after provision may require reprovisioning, because some services require globally unique names across subscriptions and resource groups.
AZURE_SUBSCRIPTION_ID=REPLACE_WITH_YOUR_SUBSCRIPTION_ID
AZURE_LOCATION=brazilsouth
RESOURCE_SUFFIX=teams-ai-chat

# Generated during provision, you can also add your own variables.
BOT_ID=
TEAMS_APP_ID=
TEAMS_APP_TENANT_ID=
BOT_AZURE_APP_SERVICE_RESOURCE_ID=
BOT_DOMAIN=

# Variables needed for SDK agent
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTID=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__AUTHTYPE=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTSECRET=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__TENANTID=
